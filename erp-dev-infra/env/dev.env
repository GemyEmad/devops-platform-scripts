# ==============================
# Dev Environment Variables
# ==============================

ENV_NAME="erp-dev"

# OS / Time
TIMEZONE="Africa/Cairo"
NTP_ALLOWED_NETWORK="192.00.00.0/00"

# Hostnames
CONTROL_PLANE_HOSTNAME="control-plane01"
WORKER01_HOSTNAME="worker01"
WORKER02_HOSTNAME="worker02"

# IPs - CHANGE THESE BEFORE RUNNING
CONTROL_PLANE_IP="192.00.00.00"
WORKER01_IP="192.00.00.00"
#WORKER02_IP="192.00.00.00"

# Kubernetes
K8S_REPO_VERSION="v1.32"
POD_NETWORK_CIDR="192.168.0.0/16"
SERVICE_CIDR="10.96.0.0/12"
K8S_API_ENDPOINT="control-plane01"
CALICO_VERSION="v3.30.3"

# Runtime
CONTAINERD_PAUSE_IMAGE="registry.k8s.io/pause:3.10"

# Paths
PROJECT_DIR="/opt/erp-dev-infra"
LOG_DIR="/opt/erp-dev-infra/logs"
JOIN_FILE="/opt/erp-dev-infra/join-worker.sh"
