# Dev Platform Settings

ENV_NAME="erp-dev"

# MetalLB
METALLB_NAMESPACE="metallb-system"
METALLB_VERSION="v0.14.8"
METALLB_IP_POOL_NAME="erp-dev-pool"
METALLB_L2_ADV_NAME="erp-dev-l2"
METALLB_IP_RANGE="00000"

# NGINX Ingress
INGRESS_NAMESPACE="ingress-nginx"
INGRESS_RELEASE_NAME="ingress-nginx"
INGRESS_CHART_VERSION="4.11.3"

# Metrics Server
METRICS_NAMESPACE="kube-system"
METRICS_RELEASE_NAME="metrics-server"
METRICS_CHART_VERSION="3.12.1"

# Kubernetes Dashboard
DASHBOARD_NAMESPACE="kubernetes-dashboard"
DASHBOARD_RELEASE_NAME="kubernetes-dashboard"
DASHBOARD_CHART_VERSION="7.10.0"
DASHBOARD_ADMIN_SA="dashboard-admin"

# Cert Manager
CERT_MANAGER_NAMESPACE="cert-manager"
CERT_MANAGER_RELEASE_NAME="cert-manager"
CERT_MANAGER_CHART_VERSION="v1.15.3"

# Paths
PROJECT_ROOT="/opt/erp-platform-sprint2"
